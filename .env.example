# =============================================================================
# AI-Powered Code Review Pipeline — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# =============================================================================

# ─── GitHub ───────────────────────────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_here
GITHUB_TOKEN=your_github_personal_access_token_here

# ─── LLM APIs ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here          # optional if using Groq

# ─── LangSmith (Tracing) ──────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=code-review-pipeline

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=code_review
POSTGRES_USER=review_user
POSTGRES_PASSWORD=your_strong_password_here
DATABASE_URL=postgresql+asyncpg://review_user:your_strong_password_here@postgres:5432/code_review

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=code_patterns

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development                              # development | production
LOG_LEVEL=INFO
API_PORT=8000

# ─── Agent Config ─────────────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.75                        # findings below this are not posted
MAX_DIFF_TOKENS=8000                             # chunk diffs larger than this
DAILY_COST_CAP_USD=5.00                          # per repo daily spending limit

# ─── Monitoring ───────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=your_grafana_password_here
