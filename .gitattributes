# Normalize line endings to LF for all files
* text=auto eol=lf

# Force LF for these file types
*.py text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.env text eol=lf
*.conf text eol=lf
Dockerfile text eol=lf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.gif binary
*.ico binary
